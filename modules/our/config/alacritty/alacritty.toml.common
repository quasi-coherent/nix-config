working_directory = "None"

[bell]
duration = 0

[selection]
save_to_clipboard = true

[mouse]
hide_when_typing = true

[cursor.style]
shape = "Block"
blinking = "Off"

[font]
builtin_box_drawing = true
size = 12

[font.normal]
family = "Hasklug Nerd Font"
style = "Regular"

[font.bold]
family = "Hasklug Nerd Font"
style = "Bold"

[font.italic]
family = "Hasklug Nerd Font"
style = "Italic"

[window]
decorations = "None"
startup_mode = "Windowed"
option_as_alt = "Both"
